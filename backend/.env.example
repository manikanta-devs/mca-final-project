# ============================================================
# AI Interview System - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# ─── Flask Configuration ─────────────────────────────────
FLASK_ENV=development
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-min-32-chars
PORT=5000

# ─── Gemini AI API Key (required) ────────────────────────
# Get your free key at: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── CORS Configuration ──────────────────────────────────
# Comma-separated list of allowed origins, or * for all origins.
# WARNING: CHANGE THIS to your production domain (e.g. https://yourdomain.com) before deploying!
ALLOWED_ORIGINS=*

# ─── Rate Limiting ───────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ─── Local LLM Fallback (Optional) ──────────────────────
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:11434

# ─── Logging ─────────────────────────────────────────────
LOG_LEVEL=INFO

# ─── App Configuration ──────────────────────────────────
MAX_QUESTIONS=10
MIN_QUESTIONS=3
SESSION_TIMEOUT_HOURS=24
